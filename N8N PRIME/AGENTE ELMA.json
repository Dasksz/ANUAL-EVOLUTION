    {
      "parameters": {
        "descriptionType": "manual",
        "toolDescription": "Use para buscar Vendas, Pedidos e Histórico. Só use se o CPF foi validado em Validar_RCA.\n{\n  \"type\": \"object\",\n  \"properties\": {\n    \"codigo_cliente\": {\n      \"type\": \"string\",\n      \"description\": \"Código numérico exato do cliente. NÃO preencha ou deduza se o usuário não fornecer.\"\n    },\n    \"cnpj\": {\n      \"type\": \"string\",\n      \"description\": \"CNPJ do cliente. OMITA esta propriedade se não souber o CNPJ. NUNCA preencha com zeros ou dados fictícios.\"\n    },\n    \"tipo_venda_pedido\": {\n      \"type\": \"string\",\n      \"description\": \"Tipo da operação. Envie 11 para Bonificação e 5 para Perda. Para tipos de venda normal, envie estritamente 1,9 sem usar espaços ou as palavras 'e/ou'.\"\n    },\n    \"numero_pedido\": {\n      \"type\": \"string\",\n      \"description\": \"Número exato do pedido. OMITA esta propriedade se não for fornecido. NUNCA preencha com 0.\"\n    },\n    \"data_inicio\": {\n      \"type\": \"string\",\n      \"description\": \"Data inicial da busca no formato YYYY-MM-DD.\"\n    },\n    \"data_fim\": {\n      \"type\": \"string\",\n      \"description\": \"Data final da busca no formato YYYY-MM-DD.\"\n    }\n  }\n}",
        "operation": "getAll",
        "tableId": "n8n_agent_view",
        "limit": 5,
        "filterType": "string",
        "filterString": "={{   [     $fromAI(\"codigo_cliente\") && !/^0+$/.test($fromAI(\"codigo_cliente\")) ? `codigo_cliente=eq.${$fromAI(\"codigo_cliente\")}` : \"\",     $fromAI(\"cnpj\") && !/^0+$/.test($fromAI(\"cnpj\")) && $fromAI(\"cnpj\").length >= 11 ? `cnpj=eq.${$fromAI(\"cnpj\")}` : \"\",     $fromAI(\"tipo_venda_pedido\") && !/^0+$/.test($fromAI(\"tipo_venda_pedido\")) ? `tipo_venda_pedido=in.(${$fromAI(\"tipo_venda_pedido\")})` : \"\",     $fromAI(\"numero_pedido\") && !/^0+$/.test($fromAI(\"numero_pedido\")) && $fromAI(\"numero_pedido\") !== $fromAI(\"codigo_cliente\") ? `numero_pedido=eq.${$fromAI(\"numero_pedido\")}` : \"\",     $fromAI(\"data_inicio\") ? `data_pedido=gte.${$fromAI(\"data_inicio\")}` : \"\",     $fromAI(\"data_fim\") ? `data_pedido=lte.${$fromAI(\"data_fim\")}` : \"\"   ].filter(x => x !== \"\").join(\"&\") || \"codigo_cliente=is.null\" }}"
      },
